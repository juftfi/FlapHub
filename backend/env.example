# ============================================
# FlapX Backend Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# Blockchain Configuration
# ============================================

# Keystore password (for encrypted private key)
# Run: npm run encrypt-key to create keystore.json
KEY_PASSWORD=your_secure_password

# BNB Chain RPC URL
RPC_URL=https://bsc-dataseed.binance.org/

# Chain ID (56 for BNB Chain mainnet)
CHAIN_ID=56

# Tax rate in basis points (300 = 3%)
TAX_RATE=300

# Token creation fee in BNB (check flap.sh for current fee)
CREATION_FEE=0.01

# ============================================
# X (Twitter) API
# ============================================

# X API Base URL
TWITTER_API_BASE_URL=https://api.x.com

# X API Key
TWITTER_API_KEY=your_x_api_key

# Bot account username (without @) - monitors this account's mentions
TWITTER_OFFICIAL_USERNAME=YourBotUsername

# ============================================
# Twitter Login (Primary Account)
# ============================================

# Account credentials for posting replies
TWITTER_LOGIN_USERNAME=your_bot_username
TWITTER_LOGIN_EMAIL=your_email@example.com
TWITTER_LOGIN_PASSWORD=your_password
TWITTER_LOGIN_2FA_SECRET=YOUR_2FA_SECRET_KEY

# ============================================
# Twitter Login (Backup Account - Optional)
# ============================================

# Fallback account if primary fails
TWITTER_BACKUP_USERNAME=backup_username
TWITTER_BACKUP_EMAIL=backup@example.com
TWITTER_BACKUP_PASSWORD=backup_password
TWITTER_BACKUP_2FA_SECRET=BACKUP_2FA_SECRET

# ============================================
# Twitter Proxy (REQUIRED)
# ============================================

# Residential proxy for Twitter login
# Format: http://username:password@host:port
TWITTER_PROXY=http://user:pass@proxy.example.com:1234

# ============================================
# Twitter OAuth 2.0 (Website Login)
# ============================================

# Get these from Twitter Developer Portal
TWITTER_CLIENT_ID=your_client_id
TWITTER_CLIENT_SECRET=your_client_secret
TWITTER_CALLBACK_URL=https://yourdomain.com/api/auth/callback

# ============================================
# API Server
# ============================================

# Port for local API server
API_PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=https://yourdomain.com

# ============================================
# Rate Limiting
# ============================================

# Minutes between token creations per user
RATE_LIMIT_MINUTES=1

# Seconds between polling Twitter for mentions
POLL_INTERVAL_SECONDS=5
